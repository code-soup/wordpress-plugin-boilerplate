{
	"name": "codesoup/wppb",
	"description": "WordPress Plugin Boilerplate",
	"homepage": "https://github.com/code-soup/wordpress-plugin-boilerplate",
	"type": "wordpress-plugin",
	"license": "GPL-3.0",
	"support": {
		"issues": "https://github.com/code-soup/wordpress-plugin-boilerplate/issues"
	},
	"authors": [
		{
			"name": "Code Soup",
			"email": "hi@codesoup.co",
			"homepage": "https://www.codesoup.co"
		}
	],
	"keywords": [
		"wppb",
		"wordpress",
		"wordpress plugin",
		"wordpress plugin boilerplate"
	],
	"autoload": {
		"files": [
			"includes/autoloader.php"
		]
	},
	"require": {
		"php": ">=8.1.0",
		"composer/installers": "^2.3",
		"vlucas/phpdotenv": "^5.6",
		"psr/container": "^2.0"
	},
	"require-dev": {
		"wp-coding-standards/wpcs": "^3.3",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.2",
		"php-parallel-lint/php-parallel-lint": "^1.4",
		"php-parallel-lint/php-console-highlighter": "^1.0"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"composer/installers": true
		},
		"platform": {
			"php": "8.1.0"
		}
	},
	"scripts": {
		"lint": "@php ./vendor/bin/parallel-lint . -e php --show-deprecated --exclude vendor --exclude .git",
		"lint:phpcs": "vendor/bin/phpcs",
		"lint:phpcbf": "vendor/bin/phpcbf"
	},
	"scripts-descriptions": {
		"lint": "Lint PHP files against parse errors",
		"lint:phpcs": "Analyze code against WordPress coding standards",
		"lint:phpcbf": "Fix coding standards warnings/errors automatically"
	},
	"minimum-stability": "dev",
	"prefer-stable": true
}
